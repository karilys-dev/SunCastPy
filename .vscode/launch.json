{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "type_coord_group_date",
            "type": "debugpy",
            "request": "launch",
            "module": "SunCastPy.main",
            "console": "integratedTerminal",
            "args": "--flatten --group-by=date --limit=3"
        },
        {
            "name": "type_city_group_date",
            "type": "debugpy",
            "request": "launch",
            "module": "SunCastPy.main",
            "console": "integratedTerminal",
            "args": "--flatten --group-by=date --limit=3 --city=${env:CITY}"
        },
        {
            "name": "type_zone_group_date",
            "type": "debugpy",
            "request": "launch",
            "module": "SunCastPy.main",
            "console": "integratedTerminal",
            "args": "--flatten --limit=1 --zone='${env:ZONE}' --output=${workspaceFolder}/artifacts/debug/zone"
        },
    ]
}